# Copy to .env.local and fill in. NEVER commit real secrets.

# Supabase — https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Gmail OAuth (notifications)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# Anthropic (receipt/bank-statement OCR)
ANTHROPIC_API_KEY=

# Public base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required (mandatory) — authorizes the Vercel cron digest endpoint
CRON_SECRET=

# Required — drives HMAC token signing + Gmail token encryption-at-rest.
# Generate with: openssl rand -base64 48
APP_SECRET=
